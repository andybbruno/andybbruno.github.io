---
import { siteConfig } from "../config";

const hasSkills =
  siteConfig.skills &&
  (siteConfig.skills.core?.length > 0 ||
    siteConfig.skills.technologies?.length > 0 ||
    siteConfig.skills.cloudProviders?.length > 0);
---

{
  hasSkills && (
    <section id="skills" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Skills
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8 space-y-6">
            {siteConfig.skills.core?.length > 0 && (
              <div class="bg-gray-50 rounded-xl sm:rounded-2xl shadow-sm border border-gray-200 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                  Focus Areas
                </h3>
                <div class="mt-4 flex flex-wrap gap-3">
                  {siteConfig.skills.core.map((skill) => (
                    <span
                      class="rounded-full px-4 py-2 text-sm sm:text-base font-medium text-white"
                      style={`background-color: ${siteConfig.accentColor}`}
                    >
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {siteConfig.skills.technologies?.length > 0 && (
              <div class="bg-gray-50 rounded-xl sm:rounded-2xl shadow-sm border border-gray-200 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                  Technologies
                </h3>
                <div class="mt-4 flex flex-wrap gap-3">
                  {siteConfig.skills.technologies.map((technology) => (
                    <span
                      class="rounded-full px-4 py-2 text-sm sm:text-base font-medium text-white"
                      style={`background-color: ${siteConfig.accentColor}`}
                    >
                      {technology}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {siteConfig.skills.cloudProviders?.length > 0 && (
              <div class="bg-gray-50 rounded-xl sm:rounded-2xl shadow-sm border border-gray-200 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                  Cloud Providers
                </h3>
                <div class="mt-4 flex flex-wrap gap-3">
                  {siteConfig.skills.cloudProviders.map((provider) => (
                    <span
                      class="rounded-full px-4 py-2 text-sm sm:text-base font-medium text-white"
                      style={`background-color: ${siteConfig.accentColor}`}
                    >
                      {provider}
                    </span>
                  ))}
                </div>
              </div>
            )}

          </div>
        </div>
      </div>
    </section>
  )
}
